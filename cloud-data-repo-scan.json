{
  "_comment": "cloud-sec-data-report::repo_scan config. Zero VM CPU — laptop-local. `~/git/vault/` NEVER scanned: intentional secrets store.",
  "enabled": true,
  "repos": [
    { "path": "~/git/cloud-data", "visibility": "public",  "scan_history": true,  "scan_tree": true },
    { "path": "~/git/cloud",      "visibility": "private", "scan_history": true,  "scan_tree": true },
    { "path": "~/git/tools",      "visibility": "public",  "scan_history": true,  "scan_tree": true },
    { "path": "~/git/unix",       "visibility": "public",  "scan_history": true,  "scan_tree": true },
    { "path": "~/git/front",      "visibility": "public",  "scan_history": true,  "scan_tree": true }
  ],
  "history_max_commits": 5000,
  "history_secs_budget": 60,
  "skip_paths_re": [
    "(^|/)vault/",
    "(^|/)I_cloud-data/",
    "(^|/)II_tools/",
    "(^|/)III_unix/",
    "(^|/)dist/\\.secrets(\\.d)?(/|$)",
    "(^|/)\\.gitmodules$",
    "(^|/)target/",
    "(^|/)node_modules/",
    "(^|/)\\.git/",
    "(^|/)z_archive/",
    "(^|/)yara-rules/",
    "\\.yar$",
    "(^|/)raw_logs/",
    "\\.jsonl$",
    "(^|/)cloud-data-repo-scan\\.json$"
  ],
  "expected_encrypted_files_re": [
    "(^|/)[^/]*secrets[^/]*\\.ya?ml(\\.(new|bak|old|tmp|orig|swp))?$",
    "(^|/)[^/]*secrets[^/]*\\.json(\\.(new|bak|old|tmp|orig|swp))?$",
    "\\.secrets\\.ya?ml$",
    "\\.secrets\\.sops\\.ya?ml$"
  ],
  "filename_allowlist_re": [
    "\\.pub$",
    "\\.pub\\.pem$",
    "\\.(cert|crt|ca)$",
    "(^|/)\\.env\\.(example|sample|template|dist)$",
    "(^|/)[^/]*secrets[^/]*\\.(example|sample|template|dist)\\.ya?ml$",
    "(^|/)[^/]*secrets[^/]*\\.ya?ml\\.(example|sample|template|dist)$",
    "(^|/)authorized_keys$",
    "(^|/)known_hosts$",
    "(^|/)public_[^/]*$",
    "(^|/)cloud-data-secrets-env-var-names\\.json$",
    "(^|/)secrets-template\\.ya?ml$",
    "(^|/)[^/]*secrets[^/]*-template\\.ya?ml$",
    "(^|/)sync_secrets\\.ya?ml$",
    "(^|/)\\.github/workflows/[^/]*secrets[^/]*\\.ya?ml$",
    "(^|/)3_secrets/dist/",
    "(^|/)secrets-schema\\.md$",
    "(^|/)test_precommit_blocks_plaintext_secret\\.sh$",
    "(^|/)_shared/secrets-[a-z]+\\.(md|ya?ml)$"
  ],
  "filename_patterns": [
    { "id": "pem_file",            "severity": "critical", "regex": "\\.pem$" },
    { "id": "key_file",            "severity": "critical", "regex": "\\.key$" },
    { "id": "keystore",            "severity": "critical", "regex": "\\.(p12|pfx|jks|bks|keystore|truststore)$" },
    { "id": "ppk_file",            "severity": "critical", "regex": "\\.ppk$" },
    { "id": "pgp_ascii_armor",     "severity": "warning",  "regex": "\\.asc$" },
    { "id": "gpg_keyfile",         "severity": "critical", "regex": "\\.gpg$" },
    { "id": "age_keyfile",         "severity": "critical", "regex": "\\.age$" },
    { "id": "age_keys_txt",        "severity": "critical", "regex": "(^|/)age[-_]?keys?\\.txt$" },
    { "id": "keepass_db",          "severity": "critical", "regex": "\\.kdbx$" },
    { "id": "password_safe",       "severity": "critical", "regex": "\\.psafe3$" },
    { "id": "ssh_private_named",   "severity": "critical", "regex": "(^|/)(id_(rsa|dsa|ed25519|ecdsa))$" },
    { "id": "ssh_private_suffix",  "severity": "critical", "regex": "_rsa$|_dsa$|_ed25519$|_ecdsa$" },
    { "id": "env_file",            "severity": "warning",  "regex": "(^|/)\\.env(\\.[^.]+)?$" },
    { "id": "credentials_file",    "severity": "critical", "regex": "(^|/)credentials(\\.json)?$" },
    { "id": "gcp_sa_json",         "severity": "critical", "regex": "service_account[^/]*\\.json$" },
    { "id": "aws_credentials",     "severity": "critical", "regex": "(^|/)\\.aws/credentials$" },
    { "id": "docker_config",       "severity": "warning",  "regex": "(^|/)\\.docker/config\\.json$" },
    { "id": "netrc",               "severity": "warning",  "regex": "(^|/)\\.netrc$" },
    { "id": "kubeconfig",          "severity": "warning",  "regex": "(^|/)(kube\\.config|kubeconfig)$" },
    { "id": "htpasswd",            "severity": "warning",  "regex": "(^|/)\\.?htpasswd$" },
    { "id": "wireguard_private",   "severity": "critical", "regex": "(^|/)(wg[^/]*-private|wg-private[^/]*|privatekey)\\.conf$" },
    { "id": "mobileprovision",     "severity": "warning",  "regex": "\\.mobileprovision$" },
    { "id": "backup_suffix",       "severity": "warning",  "regex": "\\.(bak|old|orig|tmp|swp)$" }
  ],
  "ignore_line_markers": [
    "ENC[AES256_GCM",
    "sops_version",
    "\"sops\":",
    "lastmodified:",
    "mac:",
    "pgp:"
  ],
  "content_patterns": [
    { "id": "pem_private_key",      "severity": "critical", "regex": "-----BEGIN (RSA |DSA |EC |OPENSSH |ENCRYPTED |PGP )?PRIVATE KEY( BLOCK)?-----" },
    { "id": "putty_private_key",    "severity": "critical", "regex": "PuTTY-User-Key-File-[23]:" },
    { "id": "age_private_key",      "severity": "critical", "regex": "AGE-SECRET-KEY-1[0-9A-Z]{58}" },
    { "id": "aws_access_key",       "severity": "critical", "regex": "AKIA[0-9A-Z]{16}" },
    { "id": "aws_secret_key_named", "severity": "critical", "regex": "(?i)aws(.{0,20})?(secret|access)(.{0,20})?(key|id)[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9+/=]{40}" },
    { "id": "gcp_api_key",          "severity": "critical", "regex": "AIza[0-9A-Za-z_-]{35}" },
    { "id": "gcp_service_account",  "severity": "critical", "regex": "\"type\"\\s*:\\s*\"service_account\"" },
    { "id": "gcp_oauth_refresh",    "severity": "critical", "regex": "1//0[A-Za-z0-9_-]{50,}" },
    { "id": "azure_storage_key",    "severity": "critical", "regex": "DefaultEndpointsProtocol=https;AccountKey=[A-Za-z0-9+/=]{88}" },
    { "id": "cloudflare_api_token", "severity": "critical", "regex": "(?i)(cf|cloudflare)[-_]?(api[-_]?)?token[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9_-]{40}" },
    { "id": "hetzner_api_token",    "severity": "critical", "regex": "(?i)hetzner[-_]?(api[-_]?)?token[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9]{64}" },
    { "id": "digitalocean_token",   "severity": "critical", "regex": "dop_v1_[a-f0-9]{64}" },
    { "id": "oci_api_key",          "severity": "critical", "regex": "(?i)oci[-_]?(api[-_]?)?key[\"'\\s]*[:=][\"'\\s]*ocid1\\.[a-z]+\\.[a-z0-9.-]+" },
    { "id": "github_pat_classic",   "severity": "critical", "regex": "ghp_[A-Za-z0-9]{36}" },
    { "id": "github_pat_fine",      "severity": "critical", "regex": "github_pat_[A-Za-z0-9_]{82}" },
    { "id": "github_app_install",   "severity": "critical", "regex": "gh[oprsu]_[A-Za-z0-9]{36}" },
    { "id": "gitlab_pat",           "severity": "critical", "regex": "glpat-[A-Za-z0-9_-]{20}" },
    { "id": "bitbucket_app_pw",     "severity": "critical", "regex": "ATBB[A-Za-z0-9]{32}[A-Za-z0-9]" },
    { "id": "npm_token",            "severity": "critical", "regex": "npm_[A-Za-z0-9]{36}" },
    { "id": "pypi_token",           "severity": "critical", "regex": "pypi-AgE[A-Za-z0-9_-]{50,}" },
    { "id": "docker_hub_token",     "severity": "critical", "regex": "dckr_pat_[A-Za-z0-9_-]{27,}" },
    { "id": "vault_token",          "severity": "critical", "regex": "hv[sb]\\.[A-Za-z0-9_-]{24,}" },
    { "id": "terraform_cloud",      "severity": "critical", "regex": "[A-Za-z0-9]{14}\\.atlasv1\\.[A-Za-z0-9_-]{60,}" },
    { "id": "openai_api_key",       "severity": "critical", "regex": "sk-(proj-|svcacct-)?[A-Za-z0-9_-]{40,}" },
    { "id": "anthropic_api_key",    "severity": "critical", "regex": "sk-ant-(api03|admin01)-[A-Za-z0-9_-]{90,}" },
    { "id": "groq_api_key",         "severity": "critical", "regex": "gsk_[A-Za-z0-9]{52}" },
    { "id": "cohere_api_key",       "severity": "warning",  "regex": "(?i)cohere[-_]?(api[-_]?)?key[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9]{40}" },
    { "id": "hugging_face_token",   "severity": "critical", "regex": "hf_[A-Za-z0-9]{34}" },
    { "id": "replicate_api_token",  "severity": "critical", "regex": "r8_[A-Za-z0-9]{37}" },
    { "id": "slack_token",          "severity": "critical", "regex": "xox[abprsu]-[0-9A-Za-z-]{10,}" },
    { "id": "slack_webhook",        "severity": "warning",  "regex": "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]+" },
    { "id": "discord_webhook",      "severity": "warning",  "regex": "https://discord(app)?\\.com/api/webhooks/\\d+/[A-Za-z0-9_-]+" },
    { "id": "discord_bot_token",    "severity": "critical", "regex": "[MN][A-Za-z\\d]{23}\\.[\\w-]{6}\\.[\\w-]{27}" },
    { "id": "telegram_bot_token",   "severity": "critical", "regex": "[0-9]{9,10}:AA[A-Za-z0-9_-]{33}" },
    { "id": "stripe_live",          "severity": "critical", "regex": "(sk|rk)_live_[A-Za-z0-9]{24,}" },
    { "id": "stripe_restricted",    "severity": "critical", "regex": "rk_(live|test)_[A-Za-z0-9]{24,}" },
    { "id": "sendgrid",             "severity": "critical", "regex": "SG\\.[A-Za-z0-9_-]{22}\\.[A-Za-z0-9_-]{43}" },
    { "id": "mailgun_api_key",      "severity": "critical", "regex": "key-[a-f0-9]{32}" },
    { "id": "mailchimp_api",        "severity": "critical", "regex": "[a-f0-9]{32}-us[0-9]{1,2}" },
    { "id": "twilio_sid_ac",        "severity": "warning",  "regex": "AC[a-f0-9]{32}" },
    { "id": "twilio_key_sk",        "severity": "warning",  "regex": "(?:^|[^A-Za-z0-9])SK[a-f0-9]{32}" },
    { "id": "shopify_token",        "severity": "critical", "regex": "shp(at|ca|ss|pa)_[a-fA-F0-9]{32}" },
    { "id": "notion_token",         "severity": "critical", "regex": "(^|[^A-Za-z0-9])secret_[A-Za-z0-9]{43}" },
    { "id": "linear_api_key",       "severity": "critical", "regex": "lin_api_[A-Za-z0-9]{40}" },
    { "id": "sentry_auth_token",    "severity": "critical", "regex": "sntr(ys|yu)_[A-Za-z0-9+/=_-]{40,}" },
    { "id": "datadog_api_key",      "severity": "warning",  "regex": "(?i)dd[-_]?api[-_]?key[\"'\\s]*[:=][\"'\\s]*[a-f0-9]{32}" },
    { "id": "newrelic_license",     "severity": "warning",  "regex": "(?i)new[-_]?relic[-_]?(license|api)[-_]?key[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9]{40}" },
    { "id": "pagerduty_token",      "severity": "critical", "regex": "(?i)pagerduty[-_]?(api[-_]?)?(key|token)[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9+\\-_]{20}" },
    { "id": "algolia_admin_key",    "severity": "critical", "regex": "(?i)algolia[-_]?(admin[-_]?)?api[-_]?key[\"'\\s]*[:=][\"'\\s]*[a-f0-9]{32}" },
    { "id": "resend_api_key",       "severity": "critical", "regex": "re_[A-Za-z0-9]{8}_[A-Za-z0-9]{24,}" },
    { "id": "pgp_private_key",      "severity": "critical", "regex": "-----BEGIN PGP PRIVATE KEY BLOCK-----" },
    { "id": "ssh_private_block",    "severity": "critical", "regex": "-----BEGIN OPENSSH PRIVATE KEY-----" },
    { "id": "jwt_token",            "severity": "warning",  "regex": "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}" },
    { "id": "pbkdf2_hash",          "severity": "warning",  "regex": "\\$pbkdf2-sha(256|512)\\$" },
    { "id": "argon2_hash",          "severity": "warning",  "regex": "\\$argon2i?d?\\$" },
    { "id": "bcrypt_hash",          "severity": "warning",  "regex": "\\$2[aby]?\\$\\d{2}\\$" },
    { "id": "url_embedded_creds",   "severity": "warning",  "regex": "(postgres(ql)?|mysql|mongodb|redis|amqp|ftp|https?)://[A-Za-z0-9._%+-]+:[A-Za-z0-9._%+=!*-]+@[^\\s]+" },
    { "id": "generic_high_entropy", "severity": "warning",  "regex": "(?i)(api[_-]?key|api[_-]?secret|access[_-]?token|auth[_-]?token|secret[_-]?key|bearer[_-]?token|client[_-]?secret)[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9+/=_-]{24,}" },
    { "id": "db_password_env",      "severity": "critical", "regex": "(?i)(mysql|postgres(ql)?|mariadb|mongo(db)?|redis|db|database|matomo|admin|root|user|app)_?(root_?)?password[\"'\\s]*[:=][\"'\\s]*[^'\"\\s${}]{6,}" },
    { "id": "generic_password_env", "severity": "warning",  "regex": "(?i)\\b(password|passwd|passphrase|secret)[\"'\\s]*[:=][\"'\\s]*[^'\"\\s${}]{8,}" },
    { "id": "basic_auth_header",    "severity": "critical", "regex": "(?i)authorization\\s*:\\s*basic\\s+[A-Za-z0-9+/=]{16,}" },
    { "id": "bearer_auth_header",   "severity": "critical", "regex": "(?i)authorization\\s*:\\s*bearer\\s+[A-Za-z0-9._~+/-]{20,}" }
  ]
}
