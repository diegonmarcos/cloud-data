# Repo-level git config — deployed by build.sh workflow
# Ensures submodules always sync on push/pull for all contributors + CI
[push]
	recurseSubmodules = on-demand
[submodule]
	recurse = true
[fetch]
	recurseSubmodules = on-demand
[core]
	hooksPath = 1_workflows/dist/hooks
[pull]
	rebase = true
[rebase]
	autoStash = true
[alias]
	# smart, non-destructive sync — see 1_workflows/src/scripts/cloud-git-sync.sh
	#   git sync           → remote wins on conflict (default)
	#   git sync remote    → remote wins on conflict
	#   git sync local     → local commits win on conflict
	sync = !./1_workflows/dist/scripts/cloud-git-sync.sh
